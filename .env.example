# Copy this file to .env and adjust values for your local environment.

# Docker publish port for this service.
# If Casdoor runs in Docker, configure its Local UniFace Endpoint as:
#   http://172.17.0.1:${FACEID_PORT}
FACEID_PORT=8100

# Optional shared secret. Leave empty only for local development.
# Use the same value as Casdoor provider Client secret.
FACEID_API_KEY=

# Runtime behavior.
FACEID_ENABLE_LIVENESS=true
FACEID_SIMILARITY_THRESHOLD=0.6
FACEID_LIVENESS_THRESHOLD=0.7
FACEID_DETECTOR=retinaface
FACEID_RECOGNIZER=arcface
FACEID_PARSER=bisenet
FACEID_MAX_IMAGE_BYTES=8388608

# Build-time model preload: all, core, or none.
FACEID_PRELOAD_MODE=all

# Base images. GPU must include CUDA 12 and cuDNN 9 runtime libraries for onnxruntime-gpu.
FACEID_CPU_BASE_IMAGE=python:3.11-slim
FACEID_GPU_BASE_IMAGE=nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

# GPU selection for the gpu profile: all, 0, 0,1, etc.
FACEID_GPU_DEVICES=all

# Mirrors and proxies for China-friendly builds.
APT_MIRROR=http://mirrors.aliyun.com/debian
APT_SECURITY_MIRROR=http://mirrors.aliyun.com/debian-security
UBUNTU_MIRROR=http://mirrors.aliyun.com/ubuntu
UBUNTU_SECURITY_MIRROR=http://mirrors.aliyun.com/ubuntu
UV_DEFAULT_INDEX=https://mirrors.aliyun.com/pypi/simple/
UNIFACE_GITHUB_PROXY=https://gh-proxy.org/
UNIFACE_MODEL_URL_REWRITE=

# Keep model cache inside the image/container.
UNIFACE_CACHE_DIR=/opt/uniface/models
